# Faithful Persona — client env
# Copie pra .env.local e ajuste. NUNCA commite .env.local.

# Backend mock (true) ou real (false)
VITE_USE_MOCK_BACKEND=true

# URL do backend Fastify (usado quando VITE_USE_MOCK_BACKEND=false)
VITE_API_BASE_URL=http://localhost:3000

# URL do game server Colyseus (multiplayer, futuro)
VITE_COLYSEUS_URL=ws://localhost:2567

# Sentry DSN (opcional, deixe vazio em dev)
VITE_SENTRY_DSN=

# Build/release id (CI define)
VITE_BUILD_ID=dev
