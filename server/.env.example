# Faithful Persona — server env
# Copie pra .env.local. NUNCA commite .env.local.

NODE_ENV=development
PORT=3000
COLYSEUS_PORT=2567

# Postgres (docker-compose sobe local em :5433 — host port pra não conflitar)
DATABASE_URL=postgresql://fp_app:fp_dev_pwd@127.0.0.1:5433/faithful_persona?sslmode=disable

# Redis (docker-compose sobe local em :6379)
REDIS_URL=redis://127.0.0.1:6379

# iron-session — chave com pelo menos 32 chars random
# gere com: node -e "console.log(crypto.randomBytes(48).toString('base64'))"
IRON_SESSION_PASSWORD=CHANGE_ME_to_a_strong_random_string_min_32_chars
# rotacione e mantenha a antiga aqui durante a transição
IRON_SESSION_PASSWORD_OLD=

# CORS — origin permitido
CORS_ORIGIN=http://localhost:5173

# Sentry / observabilidade
SENTRY_DSN=
LOG_LEVEL=info
